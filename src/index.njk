---
layout: layouts/base.njk
title: Hi Folks.
---
<div class="row">
  <div class="column">
    <h2 class="mb-2">{{ site.owner }}</h2>
    <p>{{ site.info }}</p>
    <p>{{ site.desc }}</p>
  </div>
</div>

<h3>Recent Posts</h3>

{% for post in collections.posts | head(site.max_post) %}
<div class="row">
  <div class="three columns left lit">
    <p class="bottom">{{ post.date | dateFormat }}</p>
  </div>
  <div class="nine columns left mb-3">
    <a href="{{ post.url }}">
      {{ post.data.title or "no title" }}
    </a>
  </div>
</div>
{% endfor %}

<h4><a href="/blog/">All Posts</a></h4>
