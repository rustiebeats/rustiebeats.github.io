---
layout: layouts/base.njk
title: All Posts
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: "/blog/{% if pagination.pageNumber %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<h2>All Posts</h2>

{% for post in posts %}
<article>
  <div class="row">
    <div class="three columns left lit">
      <p class="bottom">{{ post.date | dateFormat }}</p>
    </div>
    <div class="nine columns left mb-3">
      <a href="{{ post.url }}">
        {{ post.data.title or "no title" }}
      </a>
    </div>
  </div>
</article>
{% endfor %}

<div class="pagination-bar">
  <ul class="pagination">
    {% if pagination.href.previous %}
    <a class="mr" href="{{ pagination.href.previous }}">
      <svg width="1em" height="1em" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5z"/>
      </svg>
      <span>Recent</span>
    </a>
    {% endif %}
    {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}">
      <span>Older</span>
      <svg width="1em" height="1em" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path fill-rule="evenodd" d="M4 8a.5.5 0 0 0 .5.5h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5A.5.5 0 0 0 4 8z"/>
      </svg>
    </a>
    {% endif %}
  </ul>
</div>
